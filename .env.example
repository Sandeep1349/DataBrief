# ClickHouse database credentials
CLICKHOUSE_DB=databrief
CLICKHOUSE_USER=databrief
CLICKHOUSE_PASSWORD=changeme_strong_password

# Single local user credentials
# Generate the hash with: ./databrief.sh hash
APP_USER=admin
APP_PASSWORD_HASH=

# JWT config
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRY_HOURS=24

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=gsk_...

# Upload limits
MAX_UPLOAD_MB=3072
SAMPLE_ROW_CAP=20000
